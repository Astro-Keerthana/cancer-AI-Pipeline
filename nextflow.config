/*
 * Nextflow Configuration
 * Supports: local, SLURM (HPC), AWS Batch
 */

profiles {

    // ── Local Development ──────────────────────────────────
    standard {
        process.executor = 'local'
        process.cpus     = 4
        process.memory   = '8 GB'
        docker.enabled   = true
        docker.image     = 'python:3.10-slim'
    }

    // ── HPC / SLURM ────────────────────────────────────────
    slurm {
        process.executor  = 'slurm'
        process.queue     = 'gpu'
        process.cpus      = 8
        process.memory    = '32 GB'
        process.time      = '4h'
        singularity.enabled = true
        singularity.image   = 'docker://python:3.10-slim'
    }

    // ── AWS Batch ──────────────────────────────────────────
    aws {
        process.executor  = 'awsbatch'
        process.queue     = 'cancer-pipeline-queue'
        aws.region        = 'us-east-1'
        aws.batch.cliPath = '/usr/local/bin/aws'
        workDir           = 's3://your-bucket/nextflow-work'
    }
}

// ── Reports & Tracing ─────────────────────────────────────────
timeline { enabled = true; file = "reports/timeline.html" }
report   { enabled = true; file = "reports/report.html"   }
trace    { enabled = true; file = "reports/trace.txt"     }
dag      { enabled = true; file = "reports/dag.svg"       }
